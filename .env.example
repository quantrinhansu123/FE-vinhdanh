# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase (required for leaderboard data/storage)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
VITE_SUPABASE_EMPLOYEES_TABLE="employees"
VITE_SUPABASE_DU_AN_TABLE="du_an"
VITE_SUPABASE_TKQC_TABLE="tkqc"
VITE_SUPABASE_TEAMS_TABLE="crm_teams"
VITE_SUPABASE_AGENCIES_TABLE="crm_agencies"
VITE_SUPABASE_PRODUCTS_TABLE="crm_products"
VITE_SUPABASE_MARKETS_TABLE="crm_markets"
VITE_SUPABASE_AVATARS_BUCKET="avatars"
VITE_SUPABASE_REPORTS_TABLE="detail_reports"
VITE_SUPABASE_BUDGET_REQUESTS_TABLE="budget_requests"
VITE_SUPABASE_KPI_TEAM_MONTHLY_TARGETS_TABLE="kpi_team_monthly_targets"
VITE_SUPABASE_KPI_STAFF_MONTHLY_TARGETS_TABLE="kpi_staff_monthly_targets"
VITE_SUPABASE_MARKETING_STAFF_TABLE="marketing_staff"
VITE_SUPABASE_SYSTEM_SETTINGS_TABLE="system_settings"

# Upcare CRM API (https://crm.upcare.asia) — employee/mkt; token không commit git
# Bắt buộc tiền tố VITE_. Chỉ JWT, không ghi "Bearer ". Sau khi sửa: restart npm run dev / build lại.
VITE_UPCARE_CRM_BEARER_TOKEN=""
# Hoặc: VITE_UPCARE_API_TOKEN (cùng ý nghĩa, dùng khi tên trên bị trùng tool khác)
# Dev: tránh CORS — proxy Vite /upcare-crm → crm.upcare.asia (xem vite.config.ts)
VITE_UPCARE_CRM_USE_PROXY="true"
# Khi không dùng proxy (production nếu server cho phép CORS):
# VITE_UPCARE_CRM_API_BASE="https://crm.upcare.asia"
# Scope dự án (query mặc định project_id=8fcc90bc-a051-4396-9220-4326211bd1e5); tắt: VITE_UPCARE_CRM_PROJECT_UUID=none
# VITE_UPCARE_CRM_PROJECT_UUID="8fcc90bc-a051-4396-9220-4326211bd1e5"
# Tên query nếu backend khác: VITE_UPCARE_CRM_PROJECT_PARAM=du_an_id
# 401: app gửi thêm Cookie authorization=<JWT>. Tắt: VITE_UPCARE_CRM_AUTHORIZATION_COOKIE=false
# Dán full Cookie từ DevTools (request thành công): VITE_UPCARE_CRM_COOKIE=authorization=...; session_id=...
# Hoặc nối thêm: VITE_UPCARE_CRM_COOKIE_EXTRA=session_id=...; frontend_lang=en_US
# 500: thường là bug backend hoặc tham số không hợp lệ — thử VITE_UPCARE_CRM_PROJECT_UUID=none, kiểm tra date_from/date_to trên Network
#
# Tự refresh JWT khi API trả 401: POST /api/oauth/token (multipart) + Cookie (cần session_id trong VITE_UPCARE_CRM_COOKIE hoặc COOKIE_EXTRA).
# Cảnh báo: VITE_UPCARE_CRM_OAUTH_PASSWORD lộ trong bundle — production nên gọi OAuth qua backend.
# VITE_UPCARE_CRM_OAUTH_DB="fata-prod"
# VITE_UPCARE_CRM_OAUTH_LOGIN=""
# VITE_UPCARE_CRM_OAUTH_PASSWORD=""
# Trang chủ BXH: mặc định dùng GET /api/employee/mkt khi đã có Bearer; tắt: VITE_UPCARE_CRM_LEADERBOARD=false
# Nhãn team trên BXH (tuỳ chọn): VITE_UPCARE_CRM_LEADERBOARD_TEAM="MKT Upcare"

# Optional identity (used when role is not admin/manager/director)
VITE_USER_ROLE="user"
VITE_USER_NAME=""
VITE_USER_EMAIL=""

# Server-only secret (do not expose on frontend with VITE_ prefix)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
